    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer 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"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an AI assistant for a tax consulting agency. Return ONLY valid JSON. No explanations. No markdown.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze the client tax issue carefully.\\n\\nLead Information:\\nName: {{$json.name}}\\nTax Problem: {{$json.tax_problem}}\\nUrgency: {{$json.urgency}}\\n\\nReturn ONLY valid JSON.\\n\\nRules:\\n\\n1. urgency_level must ONLY be:\\n- LOW\\n- MEDIUM\\n- HIGH\\n\\n2. lead_score must ONLY be:\\n- COLD\\n- WARM\\n- HOT\\n\\n3. HOT means:\\n- urgent legal issue\\n- tax notice\\n- audit\\n- penalty\\n- business compliance issue\\n\\n4. WARM means:\\n- moderate tax consultation\\n- filing help\\n- GST support\\n\\n5. COLD means:\\n- general inquiry\\n- low urgency\\n- unclear issue\\n\\n6. summary must contain exactly 2 professional business sentences.\\n\\n7. email_reply must sound professional, reassuring, and client-friendly.\\n\\nReturn JSON in this EXACT structure:\\n\\n{\\\"lead_score\\\":\\\"\\\",\\\"urgency_level\\\":\\\"\\\",\\\"summary\\\":\\\"\\\",\\\"email_reply\\\":\\\"\\\"}\\n\\nReturn ONLY JSON.\"\n    }\n  ],\n  \"temperature\": 0.3\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        144,
        16
      ],
      "id": "86273dc7-53dc-4dc9-a49d-97b733226a1d",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.choices[0].message.content;\n\nconst parsed = JSON.parse(raw);\n\n// ------------------------\n// CURRENT ITEM DATA\n// ------------------------\n\nconst name = $('Clean Lead Data').item.json.name;\nconst email = $('Clean Lead Data').item.json.email;\nconst phone = $('Clean Lead Data').item.json.phone;\nconst tax_problem = $('Clean Lead Data').item.json.tax_problem;\nconst urgency_input = $('Clean Lead Data').item.json.urgency;\n\n// ------------------------\n// SMART PRIORITY LOGIC\n// ------------------------\n\nlet priority_rank = 0;\n\npriority_rank += Number(parsed.lead_score || 0);\n\nif (\n  parsed.urgency_level &&\n  parsed.urgency_level.toLowerCase().includes('high')\n) {\n  priority_rank += 50;\n}\n\nconst issue = tax_problem.toLowerCase();\n\nif (issue.includes('gst')) priority_rank += 20;\nif (issue.includes('notice')) priority_rank += 30;\nif (issue.includes('income tax')) priority_rank += 25;\nif (issue.includes('penalty')) priority_rank += 20;\nif (issue.includes('audit')) priority_rank += 40;\nif (issue.includes('legal')) priority_rank += 35;\n\nif (\n  urgency_input &&\n  urgency_input.toLowerCase().includes('urgent')\n) {\n  priority_rank += 25;\n}\n\nif (priority_rank > 100) {\n  priority_rank = 100;\n}\n//const lead_id = `${email}_${phone}_${tax_problem}`.toLowerCase();\n// ------------------------\n// RETURN FINAL DATA\n// ------------------------\n\nreturn {\n  json: {\n    name,\n    email,\n    phone,\n    tax_problem,\n    urgency_input,\n\n    lead_score: parsed.lead_score,\n    urgency_level: parsed.urgency_level,\n    summary: parsed.summary,\n    email_reply: parsed.email_reply,\n\n    priority_rank\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        384,
        16
      ],
      "id": "d435491d-b5cc-4d45-a736-cee5610a54ed",
