    {
      "parameters": {
        "sendTo": "={{ $('Create a record').item.json.fields.Email }}",
        "subject": "We Received Your Tax Consultation Request",
        "message": "=Hi {{ $('Create a record').item.json.fields.Name }},\n\n<!DOCTYPE html>\n\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n</head>\n<body style=\"font-family: Arial, sans-serif; background-color:#f4f4f4; padding:40px;\">\n\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td align=\"center\">\n\n```\n    <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff; border-radius:12px; overflow:hidden; border:1px solid #dddddd;\">\n\n      <tr>\n        <td style=\"background:#0f172a; padding:25px; text-align:center;\">\n          <h1 style=\"color:#ffffff; margin:0;\">Tax Consultancy Services</h1>\n        </td>\n      </tr>\n\n      <tr>\n        <td style=\"padding:40px; color:#333333;\">\n\n          <h2 style=\"margin-top:0;\">\n            Hello {{ $json.Name }},\n          </h2>\n\n          <p style=\"font-size:16px; line-height:1.7;\">\n            Thank you for contacting our tax consultancy team.\n          </p>\n\n          <p style=\"font-size:16px; line-height:1.7;\">\n            We have successfully received your request and our specialists are currently reviewing your case.\n          </p>\n\n          <div style=\"background:#f8fafc; border-left:4px solid #2563eb; padding:20px; margin:30px 0;\">\n            <strong>What happens next?</strong>\n            <ul style=\"padding-left:20px; line-height:1.8;\">\n              <li>A tax advisor will review your request</li>\n              <li>Our team will contact you shortly</li>\n              <li>Your information remains fully confidential</li>\n            </ul>\n          </div>\n\n          <div style=\"text-align:center; margin-top:35px;\">\n            <a href=\"https://yourwebsite.com\"\n               style=\"background:#2563eb; color:#ffffff; padding:14px 28px; text-decoration:none; border-radius:8px; font-weight:bold;\">\n              Visit Our Website\n            </a>\n          </div>\n\n          <p style=\"margin-top:40px; font-size:15px; color:#666666;\">\n            We appreciate the opportunity to assist you.\n          </p>\n\n          <p style=\"font-size:15px;\">\n            Regards,<br>\n            <strong>Tax Consultancy Team</strong>\n          </p>\n\n        </td>\n      </tr>\n\n      <tr>\n        <td style=\"background:#f1f5f9; padding:20px; text-align:center; font-size:13px; color:#666666;\">\n          © 2026 Tax Consultancy Services. All rights reserved.\n        </td>\n      </tr>\n\n    </table>\n\n  </td>\n</tr>\n```\n\n  </table>\n\n</body>\n</html>\n",
        "options": {}
      },
