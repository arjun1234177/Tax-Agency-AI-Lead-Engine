              "value": "=\n🚨 New HOT Tax Lead\n👤 NAME : {{$json.fields.Name}}\n📌 PROBLEM : {{$json.fields['Tax Problem']}}\n🔥 LEAD SCORE : {{$json.fields['Lead Score']}}\n📞 Phone: {{ $json.fields.Phone }}\n📧 Email: {{ $json.fields.Email }}\n⚠ Urgency: {{ $json.fields.Urgency }}\n📌 Score: {{ $json.fields['Lead Score'] }}\n\n🧾 Issue:\n{{ $json.fields['Tax Problem'] }}\n\n🧠 AI SUMMARY : \n{{ $json.fields['AI Summary'] }}\n"
            }
